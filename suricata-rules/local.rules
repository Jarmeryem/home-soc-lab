# Home SOC Lab — Custom Suricata Rules
# Author: Meryem Jarti
# Université Hassan 1er — FST Settat — 2025/2026

# SID 1000001 — Détection ICMP Ping (testé VM2→VM1)
alert icmp any any -> $HOME_NET any (msg:"ICMP Ping detecte"; \
  itype:8; sid:1000001; rev:1;)

# SID 1000002 — Détection scan SYN (Nmap -sS)
alert tcp any any -> $HOME_NET any (msg:"Scan SYN detecte - possible Nmap"; \
  flags:S,12; threshold:type both, track by_src, count 20, seconds 3; \
  sid:1000002; rev:1;)

# SID 1000003 — Détection scan NULL (Nmap)
alert tcp any any -> $HOME_NET any (msg:"Scan NULL detecte - possible Nmap"; \
  flags:0; sid:1000003; rev:1;)

# SID 1000004 — Détection scan FIN (Nmap)
alert tcp any any -> $HOME_NET any (msg:"Scan FIN detecte - possible Nmap"; \
  flags:F; sid:1000004; rev:1;)

# SID 1000005 — Détection scan XMAS (Nmap)
alert tcp any any -> $HOME_NET any (msg:"Scan XMAS detecte - possible Nmap"; \
  flags:FPU; sid:1000005; rev:1;)
